{
  "version": 2,
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/main.py"
    },
    {
      "source": "/assets/(.*)",
      "destination": "frontend/assets/$1"
    },
    {
      "source": "/favicon.ico",
      "destination": "frontend/favicon.png"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "frontend/index.html"
    }
  ]
}
